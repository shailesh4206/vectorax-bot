# Vectorax Trading Bot - .env Configuration Sample
# Copy to .env and fill in your values. Testnet recommended for testing.

# Delta Exchange API (get from https://app.delta.exchange/profile/api)
DELTA_API_KEY=your_delta_api_key_here
DELTA_API_SECRET=your_delta_api_secret_here

# Telegram Bot (create bot via @BotFather, get chat_id via @userinfobot)
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Trading Settings (optional overrides)
TESTNET=true
SYMBOLS=BTCUSD_PERP,ETHUSD_PERP
RISK_PERCENT=0.015
RR_RATIO=1.2
MAX_TRADES=3
CAPITAL=200
LOG_LEVEL=INFO

# Run: python main.py (or vectorax-trading-bot-single.py)

