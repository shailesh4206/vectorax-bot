# .env.example for Vectorax Trading Bot on Render
# Copy to .env locally, but NEVER commit .env
# On Render: Set these as Environment Variables in Dashboard

# Delta Exchange API (get from https://dashboard.delta.exchange/)
DELTA_API_KEY=your_delta_api_key_here
DELTA_API_SECRET=your_delta_api_secret_here

# Telegram Bot (create bot via @BotFather, get chat ID from @userinfobot)
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Trading Settings (optional, defaults shown)
TESTNET=true
SYMBOLS=BTCUSD_PERP,ETHUSD_PERP
CAPITAL=200
MAX_TRADES=3
LOG_LEVEL=INFO
SUMMARY_FILE_PATH=summary.txt

# Example for testnet: TESTNET=true, SYMBOLS=BTCUSD,ETHUSD
